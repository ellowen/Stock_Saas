    {
      "name": "Auth",
      "item": [
        {
          "name": "Auth - Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Login success\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "let jsonData = {};",
                  "try {",
                  "  jsonData = pm.response.json();",
                  "} catch (e) {",
                  "  console.log(\"Error parsing login response\", e);",
                  "}",
                  "",
                  "if (jsonData.accessToken) {",
                  "  pm.collectionVariables.set(\"access_token\", jsonData.accessToken);",
                  "  console.log(\"access_token actualizado en el environment\");",
                  "} else {",
                  "  console.log(\"No se encontró accessToken en la respuesta\");",
                  "}",
                  "",
                  "if (jsonData.refreshToken) {",
                  "  pm.collectionVariables.set(\"refresh_token\", jsonData.refreshToken);",
                  "  console.log(\"refresh_token actualizado en el environment\");",
                  "} else {",
                  "  console.log(\"No se encontró refreshToken en la respuesta\");",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"owner@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            }
          },
          "response": []
        }
      ]
    },
