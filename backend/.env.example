# Base de datos (obligatorio)
# Ejemplo MySQL: mysql://usuario:contraseña@localhost:3306/giro
DATABASE_URL=

# JWT para sesiones (obligatorio). Usar un string largo y aleatorio en producción.
JWT_SECRET=

# Opcionales: por defecto PORT=4000, JWT_EXPIRES_IN=15m, JWT_REFRESH_EXPIRES_IN=7d
# PORT=4000
# JWT_EXPIRES_IN=15m
# JWT_REFRESH_EXPIRES_IN=7d
# JWT_REFRESH_SECRET=  (si no se define, se usa JWT_SECRET)

# URL del frontend (para emails de recuperación de contraseña)
APP_URL=http://localhost:5173

# SMTP para envío de emails (opcional; si no se configura, el link de reset se imprime en consola)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# EMAIL_FROM=noreply@giro.app

# Web Push VAPID — generar con: node -e "require('web-push').generateVAPIDKeys()"
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@giro.app

# MercadoPago — https://www.mercadopago.com.ar/developers
# MP_ACCESS_TOKEN = token de producción (APP_USR-...)
# MP_PLAN_PRO_ID y MP_PLAN_ENTERPRISE_ID se obtienen corriendo setupMPPlans() una vez
MP_ACCESS_TOKEN=
MP_PLAN_PRO_ID=
MP_PLAN_ENTERPRISE_ID=

# Stripe — https://dashboard.stripe.com
# STRIPE_SECRET_KEY = sk_live_... (o sk_test_... para desarrollo)
# STRIPE_WEBHOOK_SECRET = whsec_... (desde Stripe Dashboard > Webhooks)
# STRIPE_PRICE_PRO y STRIPE_PRICE_ENTERPRISE = price_... (crear en Stripe Dashboard)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=
