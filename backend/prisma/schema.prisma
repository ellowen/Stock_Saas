// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Company {
  id                 Int         @id @default(autoincrement())
  name               String
  legalName          String?     @map("legal_name")
  taxId              String?     @map("tax_id")
  address            String?
  city               String?
  phone              String?
  email              String?
  logoUrl            String?     @map("logo_url")
  currency           String?     @default("ARS")
  industryType       String?     @default("GENERIC") @map("industry_type")
  lowStockAlerts     Boolean     @default(false) @map("low_stock_alerts")
  salesReportFreq    String?     @default("NONE") @map("sales_report_freq")
  plan               CompanyPlan @default(FREE)
  isActive           Boolean     @default(true) @map("is_active")
  trialEndsAt        DateTime?   @map("trial_ends_at")
  subscriptionStatus String?     @map("subscription_status")
  stripeCustomerId   String?     @map("stripe_customer_id")
  createdAt          DateTime    @default(now()) @map("created_at")
  updatedAt          DateTime    @updatedAt @map("updated_at")

  branches           Branch[]
  users              User[]
  products           Product[]
  sales              Sale[]
  ProductVariant     ProductVariant[]
  Inventory          Inventory[]
  InventoryMovement  InventoryMovement[]
  SaleItem           SaleItem[]
  StockTransfer      StockTransfer[]
  Attribute          Attribute[]
  customers          Customer[]
  suppliers          Supplier[]
  documents          Document[]
  purchaseOrders     PurchaseOrder[]
  taxConfigs         TaxConfig[]
  stockCounts        StockCount[]
  batches            Batch[]
  saleReturns          SaleReturn[]
  accountsReceivable   AccountReceivable[]

  @@map("companies")
}

enum CompanyPlan {
  FREE
  PRO
  ENTERPRISE
}

model Branch {
  id        Int      @id @default(autoincrement())
  companyId Int      @map("company_id")
  name      String
  code      String
  address   String?
  city      String?
  state     String?
  country   String?
  zipCode   String?  @map("zip_code")
  phone     String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company        Company             @relation(fields: [companyId], references: [id])
  inventory      Inventory[]
  inventoryMovements InventoryMovement[]
  sales          Sale[]
  stockFrom      StockTransfer[] @relation("StockTransferFrom")
  stockTo        StockTransfer[] @relation("StockTransferTo")
  User           User[]
  documents      Document[]
  purchaseOrders PurchaseOrder[]
  stockCounts    StockCount[]
  batches        Batch[]

  @@unique([companyId, code])
  @@map("branches")
}

model User {
  id        Int       @id @default(autoincrement())
  companyId Int       @map("company_id")
  branchId  Int?      @map("branch_id")
  username  String    @unique
  email     String?
  password  String    @map("password_hash")
  fullName  String    @map("full_name")
  role      UserRole
  isActive  Boolean   @default(true) @map("is_active")
  lastLogin DateTime? @map("last_login_at")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  company  Company  @relation(fields: [companyId], references: [id])
  branch   Branch?  @relation(fields: [branchId], references: [id])
  sales    Sale[]
  inventoryMovements InventoryMovement[]

  createdStockTransfers  StockTransfer[] @relation("StockTransferCreatedBy")
  approvedStockTransfers StockTransfer[] @relation("StockTransferApprovedBy")
  passwordResetTokens    PasswordResetToken[]
  documents              Document[]
  purchaseOrders         PurchaseOrder[]
  stockCounts            StockCount[]
  saleReturns            SaleReturn[]

  @@map("users")
}

enum UserRole {
  OWNER
  MANAGER
  SELLER
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  tokenHash String   @map("token_hash")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
  @@index([userId, expiresAt])
  @@map("password_reset_tokens")
}

model Product {
  id          Int      @id @default(autoincrement())
  companyId   Int      @map("company_id")
  name        String
  description String?
  category    String?
  brand       String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  company  Company          @relation(fields: [companyId], references: [id])
  variants ProductVariant[]

  @@map("products")
}

model ProductVariant {
  id        Int      @id @default(autoincrement())
  companyId Int      @map("company_id")
  productId Int      @map("product_id")
  size      String?
  color     String?
  sku       String
  barcode   String?
  price     Decimal  @db.Decimal(10, 2)
  costPrice Decimal? @map("cost_price") @db.Decimal(10, 2)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company           Company                   @relation(fields: [companyId], references: [id])
  product           Product                   @relation(fields: [productId], references: [id])
  stocks            Inventory[]
  movements         InventoryMovement[]
  items             SaleItem[]
  StockTransferItem StockTransferItem[]
  attributes        ProductVariantAttribute[]
  documentItems      DocumentItem[]
  purchaseOrderItems PurchaseOrderItem[]
  stockCountItems    StockCountItem[]
  batches            Batch[]
  saleReturnItems    SaleReturnItem[]

  @@unique([companyId, sku])
  @@unique([companyId, barcode])
  @@map("product_variants")
}

model Inventory {
  id               Int      @id @default(autoincrement())
  companyId        Int      @map("company_id")
  branchId         Int      @map("branch_id")
  productVariantId Int      @map("product_variant_id")
  quantity         Int
  minStock         Int?     @map("min_stock")
  location         String?  @map("location")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  company  Company         @relation(fields: [companyId], references: [id])
  branch   Branch          @relation(fields: [branchId], references: [id])
  variant  ProductVariant  @relation(fields: [productVariantId], references: [id])

  @@unique([companyId, branchId, productVariantId])
  @@map("inventory")
}

model InventoryMovement {
  id               Int                 @id @default(autoincrement())
  companyId        Int                 @map("company_id")
  branchId         Int                  @map("branch_id")
  productVariantId Int                  @map("product_variant_id")
  type             InventoryMovementType @map("type")
  quantityBefore   Int                  @map("quantity_before")
  quantityAfter    Int                  @map("quantity_after")
  userId           Int?                 @map("user_id")
  referenceType    String?              @map("reference_type")
  referenceId      Int?                 @map("reference_id")
  createdAt        DateTime            @default(now()) @map("created_at")

  company  Company         @relation(fields: [companyId], references: [id])
  branch   Branch          @relation(fields: [branchId], references: [id])
  variant  ProductVariant  @relation(fields: [productVariantId], references: [id])
  user     User?           @relation(fields: [userId], references: [id])

  @@index([companyId, branchId, createdAt(sort: Desc)])
  @@index([companyId, productVariantId, createdAt(sort: Desc)])
  @@map("inventory_movements")
}

enum InventoryMovementType {
  SALE
  SALE_RETURN
  MANUAL_ADJUST
  SET_QUANTITY
  TRANSFER_IN
  TRANSFER_OUT
  DOCUMENT_OUT
  PURCHASE_RECEIVE
}

model Sale {
  id                 Int           @id @default(autoincrement())
  companyId          Int           @map("company_id")
  branchId           Int           @map("branch_id")
  userId             Int           @map("user_id")
  totalAmount        Decimal       @map("total_amount") @db.Decimal(10, 2)
  totalItems         Int           @map("total_items")
  discountTotal      Decimal       @default(0) @map("discount_total") @db.Decimal(10, 2)
  paymentMethod      PaymentMethod @map("payment_method")
  paymentCashAmount  Decimal?      @map("payment_cash_amount") @db.Decimal(10, 2)
  paymentCardAmount  Decimal?      @map("payment_card_amount") @db.Decimal(10, 2)
  status             SaleStatus    @default(COMPLETED)
  notes              String?
  createdAt          DateTime      @default(now()) @map("created_at")
  updatedAt          DateTime      @updatedAt @map("updated_at")

  customerId         Int?          @map("customer_id")
  documentId         Int?          @map("document_id")

  company  Company      @relation(fields: [companyId], references: [id])
  branch   Branch       @relation(fields: [branchId], references: [id])
  user     User         @relation(fields: [userId], references: [id])
  customer Customer?    @relation(fields: [customerId], references: [id])
  items    SaleItem[]
  returns  SaleReturn[]

  @@map("sales")
}

enum PaymentMethod {
  CASH
  CARD
  MIXED
  OTHER
  CREDIT
}

enum SaleStatus {
  COMPLETED
  CANCELLED
  REFUNDED
  PENDING
}

model SaleItem {
  id               Int     @id @default(autoincrement())
  saleId           Int     @map("sale_id")
  companyId        Int     @map("company_id")
  productVariantId Int     @map("product_variant_id")
  quantity         Int
  unitPrice        Decimal @map("unit_price") @db.Decimal(10, 2)
  discount         Decimal @default(0) @db.Decimal(10, 2)
  totalPrice       Decimal @map("total_price") @db.Decimal(10, 2)

  sale    Sale           @relation(fields: [saleId], references: [id])
  company Company        @relation(fields: [companyId], references: [id])
  variant ProductVariant @relation(fields: [productVariantId], references: [id])

  @@map("sale_items")
}

model SaleReturn {
  id        Int      @id @default(autoincrement())
  saleId    Int      @map("sale_id")
  companyId Int      @map("company_id")
  userId    Int      @map("user_id")
  reason    String?
  total     Decimal  @db.Decimal(10, 2)
  createdAt DateTime @default(now()) @map("created_at")

  sale    Sale             @relation(fields: [saleId], references: [id])
  company Company          @relation(fields: [companyId], references: [id])
  user    User             @relation(fields: [userId], references: [id])
  items   SaleReturnItem[]

  @@map("sale_returns")
}

model SaleReturnItem {
  id         Int     @id @default(autoincrement())
  returnId   Int     @map("return_id")
  variantId  Int     @map("variant_id")
  quantity   Int
  unitPrice  Decimal @db.Decimal(10, 2) @map("unit_price")

  saleReturn SaleReturn     @relation(fields: [returnId], references: [id], onDelete: Cascade)
  variant    ProductVariant @relation(fields: [variantId], references: [id])

  @@map("sale_return_items")
}

model StockTransfer {
  id               Int                 @id @default(autoincrement())
  companyId        Int                 @map("company_id")
  fromBranchId     Int                 @map("from_branch_id")
  toBranchId       Int                 @map("to_branch_id")
  status           StockTransferStatus @default(PENDING)
  createdByUserId  Int                 @map("created_by_user_id")
  approvedByUserId Int?                @map("approved_by_user_id")
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")

  company    Company             @relation(fields: [companyId], references: [id])
  fromBranch Branch              @relation("StockTransferFrom", fields: [fromBranchId], references: [id])
  toBranch   Branch              @relation("StockTransferTo", fields: [toBranchId], references: [id])
  createdBy  User                @relation("StockTransferCreatedBy", fields: [createdByUserId], references: [id])
  approvedBy User?               @relation("StockTransferApprovedBy", fields: [approvedByUserId], references: [id])
  items      StockTransferItem[]

  @@map("stock_transfers")
}

enum StockTransferStatus {
  PENDING
  IN_TRANSIT
  COMPLETED
  CANCELLED
}

model StockTransferItem {
  id               Int @id @default(autoincrement())
  stockTransferId  Int @map("stock_transfer_id")
  productVariantId Int @map("product_variant_id")
  quantity         Int

  transfer StockTransfer  @relation(fields: [stockTransferId], references: [id])
  variant  ProductVariant @relation(fields: [productVariantId], references: [id])

  @@map("stock_transfer_items")
}

// ── Atributos flexibles de variantes ────────────────────────────────────────

enum AttributeType {
  TEXT
  NUMBER
  SELECT
}

model Attribute {
  id        Int           @id @default(autoincrement())
  companyId Int           @map("company_id")
  name      String
  type      AttributeType @default(TEXT)
  options   String?       // JSON array para type=SELECT, ej: '["Rojo","Azul"]'
  sortOrder Int           @default(0) @map("sort_order")
  createdAt DateTime      @default(now()) @map("created_at")

  company Company                   @relation(fields: [companyId], references: [id])
  values  ProductVariantAttribute[]

  @@unique([companyId, name])
  @@map("attributes")
}

model ProductVariantAttribute {
  id          Int    @id @default(autoincrement())
  variantId   Int    @map("variant_id")
  attributeId Int    @map("attribute_id")
  value       String

  variant   ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  attribute Attribute      @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  @@unique([variantId, attributeId])
  @@map("product_variant_attributes")
}

// ── Clientes y Proveedores ───────────────────────────────────────────────────

model Customer {
  id        Int      @id @default(autoincrement())
  companyId Int      @map("company_id")
  name      String
  taxId     String?  @map("tax_id")
  taxType   String?  @map("tax_type")
  address   String?
  city      String?
  email     String?
  phone     String?
  notes     String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company            Company             @relation(fields: [companyId], references: [id])
  documents          Document[]
  sales              Sale[]
  accountsReceivable AccountReceivable[]

  @@index([companyId])
  @@map("customers")
}

model Supplier {
  id        Int      @id @default(autoincrement())
  companyId Int      @map("company_id")
  name      String
  taxId     String?  @map("tax_id")
  address   String?
  city      String?
  email     String?
  phone     String?
  notes     String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company        Company         @relation(fields: [companyId], references: [id])
  purchaseOrders PurchaseOrder[]

  @@index([companyId])
  @@map("suppliers")
}

// ── Configuración de impuestos ───────────────────────────────────────────────

model TaxConfig {
  id        Int     @id @default(autoincrement())
  companyId Int     @map("company_id")
  name      String
  rate      Decimal @db.Decimal(5, 4)
  isDefault Boolean @default(false) @map("is_default")
  isActive  Boolean @default(true) @map("is_active")

  company Company        @relation(fields: [companyId], references: [id])
  items   DocumentItem[]

  @@unique([companyId, name])
  @@map("tax_configs")
}

// ── Documentos comerciales ───────────────────────────────────────────────────

enum DocumentType {
  QUOTE
  REMITO
  INVOICE
  CREDIT_NOTE
}

enum DocumentStatus {
  DRAFT
  ISSUED
  ACCEPTED
  CANCELLED
}

model Document {
  id            Int            @id @default(autoincrement())
  companyId     Int            @map("company_id")
  branchId      Int            @map("branch_id")
  userId        Int            @map("user_id")
  customerId    Int?           @map("customer_id")
  type          DocumentType
  number        Int
  status        DocumentStatus @default(DRAFT)
  date          DateTime       @default(now())
  dueDate       DateTime?      @map("due_date")
  notes         String?
  subtotal      Decimal        @db.Decimal(10, 2) @default(0)
  taxTotal      Decimal        @db.Decimal(10, 2) @default(0) @map("tax_total")
  discountTotal Decimal        @db.Decimal(10, 2) @default(0) @map("discount_total")
  total         Decimal        @db.Decimal(10, 2) @default(0)
  relatedDocId  Int?           @map("related_doc_id")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  company    Company        @relation(fields: [companyId], references: [id])
  branch     Branch         @relation(fields: [branchId], references: [id])
  user       User           @relation(fields: [userId], references: [id])
  customer   Customer?      @relation(fields: [customerId], references: [id])
  items      DocumentItem[]
  relatedDoc Document?      @relation("RelatedDoc", fields: [relatedDocId], references: [id])
  relatedTo  Document[]     @relation("RelatedDoc")

  @@unique([companyId, type, number])
  @@index([companyId, type, status])
  @@map("documents")
}

model DocumentItem {
  id          Int     @id @default(autoincrement())
  documentId  Int     @map("document_id")
  variantId   Int?    @map("variant_id")
  description String
  quantity    Decimal @db.Decimal(10, 3)
  unitPrice   Decimal @db.Decimal(10, 2) @map("unit_price")
  discount    Decimal @db.Decimal(10, 2) @default(0)
  taxConfigId Int?    @map("tax_config_id")
  taxAmount   Decimal @db.Decimal(10, 2) @default(0) @map("tax_amount")
  totalPrice  Decimal @db.Decimal(10, 2) @map("total_price")
  sortOrder   Int     @default(0) @map("sort_order")

  document  Document        @relation(fields: [documentId], references: [id], onDelete: Cascade)
  variant   ProductVariant? @relation(fields: [variantId], references: [id])
  taxConfig TaxConfig?      @relation(fields: [taxConfigId], references: [id])

  @@map("document_items")
}

// ── Órdenes de compra ────────────────────────────────────────────────────────

enum PurchaseOrderStatus {
  DRAFT
  SENT
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

model PurchaseOrder {
  id         Int                 @id @default(autoincrement())
  companyId  Int                 @map("company_id")
  branchId   Int                 @map("branch_id")
  supplierId Int                 @map("supplier_id")
  userId     Int                 @map("user_id")
  number     Int
  status     PurchaseOrderStatus @default(DRAFT)
  date       DateTime            @default(now())
  expectedAt DateTime?           @map("expected_at")
  notes      String?
  total      Decimal             @db.Decimal(10, 2) @default(0)
  createdAt  DateTime            @default(now()) @map("created_at")
  updatedAt  DateTime            @updatedAt @map("updated_at")

  company  Company             @relation(fields: [companyId], references: [id])
  branch   Branch              @relation(fields: [branchId], references: [id])
  supplier Supplier            @relation(fields: [supplierId], references: [id])
  user     User                @relation(fields: [userId], references: [id])
  items    PurchaseOrderItem[]

  @@unique([companyId, number])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id          Int     @id @default(autoincrement())
  orderId     Int     @map("order_id")
  variantId   Int?    @map("variant_id")
  description String
  quantity    Decimal @db.Decimal(10, 3)
  unitPrice   Decimal @db.Decimal(10, 2) @map("unit_price")
  received    Decimal @db.Decimal(10, 3) @default(0)

  order   PurchaseOrder   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id])

  @@map("purchase_order_items")
}

enum StockCountStatus {
  OPEN
  APPLIED
  CANCELLED
}

model StockCount {
  id        Int              @id @default(autoincrement())
  companyId Int              @map("company_id")
  branchId  Int              @map("branch_id")
  status    StockCountStatus @default(OPEN)
  notes     String?
  createdAt DateTime         @default(now()) @map("created_at")
  closedAt  DateTime?        @map("closed_at")
  createdBy Int              @map("created_by")

  company Company          @relation(fields: [companyId], references: [id])
  branch  Branch           @relation(fields: [branchId], references: [id])
  user    User             @relation(fields: [createdBy], references: [id])
  items   StockCountItem[]

  @@map("stock_counts")
}

model StockCountItem {
  id           Int        @id @default(autoincrement())
  stockCountId Int        @map("stock_count_id")
  variantId    Int        @map("variant_id")
  systemQty    Int        @map("system_qty")
  countedQty   Int?       @map("counted_qty")

  stockCount StockCount     @relation(fields: [stockCountId], references: [id], onDelete: Cascade)
  variant    ProductVariant @relation(fields: [variantId], references: [id])

  @@unique([stockCountId, variantId])
  @@map("stock_count_items")
}

model Batch {
  id          Int       @id @default(autoincrement())
  companyId   Int       @map("company_id")
  variantId   Int       @map("variant_id")
  branchId    Int       @map("branch_id")
  batchNumber String    @map("batch_number")
  expiresAt   DateTime? @map("expires_at")
  quantity    Int       @default(0)
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  company Company        @relation(fields: [companyId], references: [id])
  variant ProductVariant @relation(fields: [variantId], references: [id])
  branch  Branch         @relation(fields: [branchId], references: [id])

  @@map("batches")
}

// ── Cuenta corriente ─────────────────────────────────────────────────────────

enum ARStatus {
  PENDING
  PARTIAL
  PAID
  OVERDUE
}

model AccountReceivable {
  id         Int       @id @default(autoincrement())
  companyId  Int       @map("company_id")
  customerId Int       @map("customer_id")
  saleId     Int?      @map("sale_id")
  amount     Decimal   @db.Decimal(10, 2)
  paid       Decimal   @default(0) @db.Decimal(10, 2)
  dueDate    DateTime? @map("due_date")
  status     ARStatus  @default(PENDING)
  notes      String?
  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")

  company  Company     @relation(fields: [companyId], references: [id])
  customer Customer    @relation(fields: [customerId], references: [id])
  payments ARPayment[]

  @@index([companyId, customerId])
  @@index([companyId, status])
  @@map("accounts_receivable")
}

model ARPayment {
  id             Int           @id @default(autoincrement())
  receivableId   Int           @map("receivable_id")
  amount         Decimal       @db.Decimal(10, 2)
  method         PaymentMethod
  notes          String?
  createdAt      DateTime      @default(now()) @map("created_at")

  receivable AccountReceivable @relation(fields: [receivableId], references: [id], onDelete: Cascade)

  @@map("ar_payments")
}
